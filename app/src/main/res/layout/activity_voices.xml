<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="10dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a voice to download it. Long-press an installed voice to delete."
        android:textColor="@color/fg_dim"
        android:textSize="12sp"
        android:paddingBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LANGUAGE"
        android:textColor="@color/fg_dim"
        android:textSize="11sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerLang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:backgroundTint="@color/fg_dim" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDownloadAll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download all shown voices" />

    <TextView
        android:id="@+id/tvAllStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent2"
        android:textSize="12sp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/allProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVoices"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="6dp" />

</LinearLayout>
